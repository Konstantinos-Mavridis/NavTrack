# ── Project ──────────────────────────────────────────────────────────────────
# Used to name images (ghcr.io/PROJECT_NAMESPACE/PROJECT_NAME-*:latest),
# Docker volumes, and Docker networks. Change when forking or renaming.
COMPOSE_PROJECT_NAME=navtrack
CONTAINER_REGISTRY_NAMESPACE=konstantinos-mavridis

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=navtrack_db
POSTGRES_USER=navtrack_user
POSTGRES_PASSWORD=navtrack_pass

# ── Backend ─────────────────────────────────────────────────────────────────
BACKEND_PORT=8080

# ── Worker ──────────────────────────────────────────────────────────────────
# Set to "false" to skip the full Yahoo Finance NAV sync when the worker
# container starts. The default "true" keeps the DB up-to-date immediately
# after a restart. Use "false" if you want to avoid hitting Yahoo Finance
# rate limits on every boot and are happy to rely on the scheduled syncs
# or the Sync button in the UI / POST /api/sync/all.
SYNC_ON_STARTUP=true

# ── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000

# VITE_API_BASE_URL is baked in at frontend BUILD time.
# With the nginx proxy config the default /api works for local Docker Compose.
# Change only if you expose backend on a different host/path in production.
# VITE_API_BASE_URL=/api
