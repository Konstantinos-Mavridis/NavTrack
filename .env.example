# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=navtrack_db
POSTGRES_USER=navtrack_user
POSTGRES_PASSWORD=navtrack_pass

# ── Backend ─────────────────────────────────────────────────────────────────
BACKEND_PORT=8080

# ── Worker ──────────────────────────────────────────────────────────────────
# Set to "true" to run a full Yahoo Finance NAV sync when the worker container
# starts. Leave "false" (default) to avoid hitting rate limits on every restart.
# Use the Sync button in the UI or POST /api/sync/all for on-demand syncing.
SYNC_ON_STARTUP=false

FRONTEND_PORT=3000

# ── Project ──────────────────────────────────────────────────────────────────
# Used to name images (ghcr.io/PROJECT_NAMESPACE/PROJECT_NAME-*:latest),
# Docker volumes, and Docker networks. Change when forking or renaming.
PROJECT_NAME=navtrack
PROJECT_NAMESPACE=konstantinos-mavridis

# VITE_API_BASE_URL is baked in at frontend BUILD time.
# With the nginx proxy config the default /api works for local Docker Compose.
# Change only if you expose backend on a different host/path in production.
# VITE_API_BASE_URL=/api
